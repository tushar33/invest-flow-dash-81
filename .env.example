# Backend API base URL — no trailing slash.
# Vite only exposes variables prefixed with VITE_
#
# Committed env files:
#   .env.development  → npm run dev   (localhost)
#   .env.production   → npm run build (Render)
#
# Optional: copy this to .env.local for personal overrides (gitignored)

VITE_API_BASE=http://localhost:3000
